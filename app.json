{
  "expo": {
    "name": "Vasudha Oils",
    "slug": "vasudha-oils-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vasudha-oils-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f3d2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.vasudhaoils.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Vasudha Oils needs camera to scan QR codes on containers and capture pickup photos.",
        "NSLocationWhenInUseUsageDescription": "Vasudha Oils needs your location to record GPS coordinates for pickups.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Vasudha Oils needs background location to track active pickups in real time.",
        "NSPhotoLibraryUsageDescription": "Vasudha Oils needs photo library access to attach images to pickups."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f3d2e"
      },
      "package": "in.vasudhaoils.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Vasudha Oils needs camera to scan QR codes on containers and capture pickup photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Vasudha Oils needs background location to track active pickups in real time.",
          "locationWhenInUsePermission": "Allow Vasudha Oils to access your location for pickup GPS verification."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0f3d2e",
          "defaultChannel": "vasudha-default",
          "enableBackgroundRemoteNotifications": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
